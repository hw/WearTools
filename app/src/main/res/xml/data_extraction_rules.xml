<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup/transfer rules (API 31+). User settings (true-north, altitude unit, last tool) are backed
  up by default; the per-device level calibration is excluded from both cloud backup and device
  transfer because the zero offset is specific to this watch's accelerometer bias.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude
            domain="sharedpref"
            path="toolsftw_calibration.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude
            domain="sharedpref"
            path="toolsftw_calibration.xml" />
    </device-transfer>
</data-extraction-rules>
